{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "opencode-go": {
      "model": "opencode-go/deepseek-v4-flash"
    }
  },

  "model": {
    "default": "opencode-go/deepseek-v4-flash",
    "fallback": null
  },

  "experimental": {
    "max_auto_retry": 0,
    "disable_fallback": true
  },

  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },

  "plugin": [
    "~/.config/opencode/node_modules/superpowers"
  ],

  "skills": {
    "paths": [
      ".opencode/skills",
      "~/.config/opencode/skills",
      "~/.config/opencode/node_modules/superpowers/skills"
    ]
  },

  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow"
  }
}
